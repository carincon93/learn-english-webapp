---
import "../../shared/styles/global.css";
import "../../features/speech/styles/VoiceRecorder.css";
import "../../features/cards/styles/CardsGame.css";
import "../../shared/styles/Drawer.css";
import "../../shared/styles/Toast.css";
import "@carincon93/weird-ui/styles.css";

import { ClientRouter } from "astro:transitions";
import DynamicIsland from "../../shared/components/DynamicIsland";

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<ClientRouter />
	</head>
	<body>
		<DynamicIsland client:load transition:persist>
			<slot name="island-content" />
		</DynamicIsland>
		<slot />

		<script>
			document.addEventListener("astro:before-preparation", (event) => {
				// Dispatch a custom event
				const routeAboutToChangeEvent = new CustomEvent(
					"route-about-to-change",
					{
						detail: event.to,
					},
				);
				document.dispatchEvent(routeAboutToChangeEvent);
			});
		</script>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
