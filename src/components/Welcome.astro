---
import astroLogo from "../assets/astro.svg";
---

<div id="container">
	<main>
		<section id="hero">
			<h1>
				<span class="gradient-text">Weird</span> Ways to Learn English
			</h1>
			<section id="links">
				<a href="/pronunciation" class="link-card">
					<h3>Pronunciation Game</h3>
					<p>Test your accent and improve your clarity.</p>
				</a>
				<a href="/speech" class="link-card">
					<h3>Speech to Text</h3>
					<p>Transcribe your voice and capture your thoughts.</p>
				</a>
			</section>
		</section>
	</main>
</div>

<style>
	#container {
		height: 100%;
	}

	main {
		height: 100%;
	}

	#hero {
		display: flex;
		align-items: start;
		flex-direction: column;
		justify-content: center;
		padding: 16px;
		width: 100%;
		max-width: 90dvw;

		h1 {
			font-size: 6rem;
			max-width: 60dvw;
			margin-top: 0.25em;
			line-height: 0.98;
		}

		#links {
			display: flex;
			gap: 1.5rem;
			margin-top: 3rem;
			flex-wrap: wrap;
		}

		.link-card {
			flex: 1;
			min-width: 280px;
			padding: 1.5rem;
			background: rgba(255, 255, 255, 0.05);
			border: 1px solid rgba(255, 255, 255, 0.1);
			border-radius: 1.25rem;
			text-decoration: none;
			color: white;
			transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
			backdrop-filter: blur(10px);
		}

		.link-card:hover {
			background: rgba(255, 255, 255, 0.1);
			transform: translateY(-5px);
			border-color: rgba(255, 255, 255, 0.2);
			box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
		}

		.link-card h3 {
			margin: 0;
			font-size: 1.5rem;
			background: linear-gradient(135deg, #ff8c42, #ffa600);
			-webkit-background-clip: text;
			background-clip: text;
			-webkit-text-fill-color: transparent;
		}

		.link-card p {
			margin: 0.5rem 0 0;
			opacity: 0.7;
			font-size: 0.95rem;
			line-height: 1.5;
		}
	}

	.gradient-text {
		background: linear-gradient(
			135deg,
			#ff6b35 0%,
			#ff8c42 25%,
			#ffa600 50%,
			#ff8c42 75%,
			#ff6b35 100%
		);
		-webkit-background-clip: text;
		background-clip: text;
		-webkit-text-fill-color: transparent;
		background-size: 200% auto;
		animation: gradient-shift 3s ease infinite;
		filter: drop-shadow(0 0 30px rgba(255, 140, 66, 0.2))
			drop-shadow(0 0 60px rgba(255, 107, 53, 0.3))
			drop-shadow(0 0 90px rgba(255, 166, 0, 0.2));
	}

	@keyframes gradient-shift {
		0%,
		100% {
			background-position: 0% center;
		}
		50% {
			background-position: 100% center;
		}
	}

	@media screen and (max-width: 768px) {
		#container {
			display: flex;
			flex-direction: column;
		}

		#hero {
			display: block;
			padding-top: 10%;
		}

		#video-background video {
			transform: translate(-75%, -50%);
		}
	}

	@media screen and (min-width: 769px) and (max-width: 1024px) {
		#video-background video {
			transform: translate(-70%, -50%);
		}
	}

	@media screen and (min-width: 1025px) and (max-width: 1399px) {
		#video-background video {
			transform: translate(-60%, -50%);
		}
	}

	@media screen and (min-width: 1400px) {
		#video-background video {
			transform: translate(-50%, -50%);
		}

		#hero h1 {
			font-size: 9rem;
		}
	}
</style>
