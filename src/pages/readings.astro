---
import "../features/readings/styles/Readings.css";

import Layout from "../app/layout/Layout.astro";
import SpeechControls from "../features/speech/components/SpeechControls";
import ReadingsDisplay from "../features/readings/components/ReadingsDisplay";

import { prisma } from "../../db/db";

const readings = await prisma.reading.findMany({ take: 1 });
const initialText = readings[0]?.text || "";
const phoneticTranscriptions = await prisma.phoneticTranscription.findMany();

const initialPhonetics = JSON.stringify(phoneticTranscriptions);
---

<Layout title="Readings - Weird English">
  <div slot="island-content" class="dynamic-island__component-content"></div>

  <main
    class="readings__container"
    data-initial-text={initialText}
    data-initial-phonetics={initialPhonetics}
  >
    <ReadingsDisplay client:only="react" />
  </main>

  <div id="readingControls" class="readings__controls">
    <button id="clearAllBtn">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path
          d="M20 14V8a2.4 2.4 0 0 0-.706-1.706l-3.588-3.588A2.4 2.4 0 0 0 14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12"
        ></path>
        <path d="M14 2v5a1 1 0 0 0 1 1h5"></path><path d="M14 18h6"></path>
      </svg>
    </button>

    <button id="openDrawerBtn">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path
          d="M11.35 22H6a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h8a2.4 2.4 0 0 1 1.706.706l3.588 3.588A2.4 2.4 0 0 1 20 8v5.35"
        ></path>
        <path d="M14 2v5a1 1 0 0 0 1 1h5"></path><path d="M14 19h6"></path>
        <path d="M17 16v6"></path>
      </svg>
    </button>
    <SpeechControls client:load />
  </div>

  <!-- <BottomDrawer client:load>
    <div class="readings__input-area">
      <textarea
        id="readingsInputTextarea"
        class="readings__input-text"
        placeholder="Paste or type your text here..."></textarea>
      <div class="readings__input-area__button">
        <Button client:only="react" />
      </div>
    </div>
  </BottomDrawer> -->

  <script>
    import gsap from "gsap";
    import { actions } from "astro:actions";
    import {
      setReadingAction,
      clearReadingAction,
      updatePhoneticsAction,
    } from "../features/readings/stores/readingsStore";
    import {
      openInputDrawer,
      closeInputDrawer,
    } from "../shared/stores/uiStore";

    document.addEventListener("astro:page-load", () => {
      const textarea = document.getElementById(
        "readingsInputTextarea",
      ) as HTMLTextAreaElement;
      const processTextBtn = document.getElementById("processTextBtn");
      const openDrawerBtn = document.getElementById("openDrawerBtn");
      const clearAllBtn = document.getElementById("clearAllBtn");

      openDrawerBtn?.addEventListener("click", () => openInputDrawer());

      textarea?.addEventListener("input", () => {
        if (textarea.value.trim()) {
          processTextBtn?.removeAttribute("disabled");
        } else {
          processTextBtn?.setAttribute("disabled", "true");
        }
      });

      processTextBtn?.addEventListener("click", processText);
      clearAllBtn?.addEventListener("click", clearAll);

      async function clearAll() {
        const { error } = await actions.deleteAllReadings({});
        if (error) {
          console.error("Delete All Readings Error:", error);
          alert("Failed to delete readings.");
          return;
        }
        clearReadingAction();
      }

      async function processText() {
        if (!textarea) return;
        const text = textarea.value.trim();
        if (!text) return;

        // Optimistically or after success: update the store
        await actions.deleteAllReadings({});

        const { error } = await actions.saveReading({
          readingId: Date.now().toString(),
          text,
        });

        if (error) {
          console.error("Save Reading Error:", error);
          alert("Failed to save reading. Please try again.");
          return;
        }

        const { data: phoneticData, error: phoneticError } =
          await actions.phoneticTranscription({
            text,
          });

        if (phoneticError) {
          console.error("Phonetic Transcription Error:", phoneticError);
          alert("Failed to transcribe text. Please try again.");
          return;
        }

        if (phoneticData?.transcription) {
          const entries = phoneticData.transcription.split(",");
          const mapping: Record<string, string> = {};
          entries.forEach((entry) => {
            const parts = entry.split(":");
            if (parts.length >= 2) {
              mapping[parts[0].trim().toLowerCase()] = parts[1].trim();
            }
          });
          updatePhoneticsAction(mapping);
        }

        setReadingAction(text);
        textarea.value = "";
        closeInputDrawer();
      }

      // Initialize store with server-side data
      const container = document.querySelector(
        ".readings__container",
      ) as HTMLElement;
      const initialText = container?.dataset.initialText || "";
      if (initialText) {
        setReadingAction(initialText);
      }

      // Initialize phonetics store
      const initialPhoneticsRaw = container?.dataset.initialPhonetics;
      if (initialPhoneticsRaw) {
        try {
          const list = JSON.parse(initialPhoneticsRaw);
          const mapping = list.reduce((acc: any, item: any) => {
            acc[item.word.toLowerCase()] = item.phoneticTranscription;
            return acc;
          }, {});
          updatePhoneticsAction(mapping);
        } catch (e) {
          console.error("Failed to parse initial phonetics:", e);
        }
      }

      // --- Entrance Animations ---
      const readingControls = document.getElementById("readingControls");
      if (readingControls) {
        gsap.from(readingControls, {
          y: 100,
          opacity: 0,
          duration: 1,
          ease: "power4.out",
          delay: 0.3,
        });
      }
    });
  </script>
</Layout>
