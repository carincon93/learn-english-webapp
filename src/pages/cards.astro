---
import CardsGame from "../features/cards/components/CardsGame";
import Layout from "../app/layout/Layout.astro";
import { prisma } from "../../db/db";

const phrases = await prisma.phrase.findMany();
---

<Layout title="Cards">
    <div slot="island-content">
        <div style="display: flex; gap: 1rem; align-items: center;">
            <a
                href="/readings"
                style="color: white; opacity: 0.7; text-decoration: none;"
            >
                Readings
            </a>
            <span style="opacity: 0.3;">|</span>
            <span style="font-weight: bold;">Cards Game</span>
        </div>
    </div>
    <main>
        <CardsGame client:load initialPhrases={phrases} />
    </main>
</Layout>
